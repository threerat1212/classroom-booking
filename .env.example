DATABASE_URL=postgres://classroom:classroom@localhost:5432/classroom_db?sslmode=disable
JWT_SECRET=change-me-in-production
JWT_REFRESH_SECRET=change-me-in-production-too
API_PORT=8080
UPLOAD_DIR=./uploads
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
TEACHER_INVITE_CODE=change-this-teacher-invite-code

# AI tutor provider options:
# 1) openrouter - use OpenRouter (OpenAI-compatible, many free models)
#    Free models: nvidia/nemotron-3-nano-omni-30b-a3b-reasoning:free, arcee-ai/trinity-large-thinking:free
#    Get key: https://openrouter.ai/keys
# 2) google     - use Google Gemini API directly (get key from https://aistudio.google.com/app/apikey)
#    BaseURL example: https://generativelanguage.googleapis.com/v1beta/models/gemini-1.5-flash:generateContent
# 3) groq       - use Groq API (get key from https://console.groq.com)
#    BaseURL: https://api.groq.com/openai/v1/chat/completions
#    Models: llama-3.3-70b-versatile, mixtral-8x7b-32768

AI_PROVIDER=openrouter
AI_API_KEY=your-api-key
AI_BASE_URL=https://openrouter.ai/api/v1/chat/completions
AI_MODEL=nvidia/nemotron-3-nano-omni-30b-a3b-reasoning:free
# Model used specifically for grading student answers.
# Trinity verified 5/5 accuracy on lenient grading + Thai/English equivalence.
AI_GRADING_MODEL=arcee-ai/trinity-large-thinking:free
AI_APP_NAME=Classroom MS AI Tutor
AI_SITE_URL=http://localhost:3000

NEXT_PUBLIC_API_URL=http://localhost:8080
NEXT_PUBLIC_GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
